{
  "name": "ng-openapi-signals",
  "version": "0.7.1",
  "description": "Signal-first OpenAPI client generator for Angular using resource() and fetch().",
  "type": "module",
  "bin": {
    "ng-openapi-signals": "./dist/cli.mjs"
  },
  "exports": {
    "./config": {
      "import": "./dist/config.mjs",
      "types": "./dist/config.d.mts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsdown",
    "test": "vitest",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "generate:example": "npm run build && node dist/cli.mjs generate --config ng-openapi-signals.config.ts",
    "check:example": "npm run build && node dist/cli.mjs generate --config ng-openapi-signals.config.ts --check"
  },
  "keywords": [
    "angular",
    "angular-22",
    "openapi",
    "swagger",
    "signals",
    "resource",
    "fetch",
    "codegen",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ynnckrkn/ng-openapi-signals.git"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "commander": "^15.0.0",
    "jiti": "^2.7.0",
    "prettier": "^3.9.4",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "tsdown": "^0.22.5",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@angular/core": ">=22.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
